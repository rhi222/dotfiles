{
  "agentPushNotifEnabled": true,
  "enabledPlugins": {
    "cdk@forcia-claude-marketplace": true,
    "codex@openai-codex": true,
    "commit-commands@forcia-claude-marketplace": true,
    "domain-model@forcia-claude-marketplace": true,
    "example-skills@anthropic-agent-skills": true,
    "superpowers@claude-plugins-official": true,
    "typescript@forcia-claude-marketplace": true
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "claude-opus-4-8"
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "repo": "anthropics/skills",
        "source": "github"
      }
    },
    "forcia-claude-marketplace": {
      "source": {
        "source": "git",
        "url": "git@github.com:forcia/claude_marketplace.git"
      }
    },
    "openai-codex": {
      "source": {
        "repo": "openai/codex-plugin-cc",
        "source": "github"
      }
    }
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "$HOME/.config/claude/hooks/notify-windows.sh",
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '~/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "$HOME/.config/claude/hooks/notify-windows.sh",
            "type": "command"
          }
        ]
      }
    ]
  },
  "includeCoAuthoredBy": false,
  "language": "Japanese",
  "mcpServers": {
    "drawio": {
      "args": ["@drawio/mcp"],
      "command": "npx"
    }
  },
  "permissions": {
    "allow": [
      "Bash(awk:*)",
      "Bash(cp:*)",
      "Bash(find:*)",
      "Bash(gh pr diff:*)",
      "Bash(git remote show:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm test:*)",
      "Bash(rg:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(pnpm type-check:*)",
      "Bash(pnpm tsc:*)",
      "Bash(pnpm biome:check:*)",
      "Bash(glab mr view:*)",
      "Bash(oc get:*)",
      "mcp__claude_ai_Slack__slack_search_public_and_private",
      "mcp__jira-mcp__getJiraIssue",
      "mcp__claude_ai_Google_Calendar__list_events"
    ],
    "ask": ["Bash(aws:*)", "Bash(rm:*)", "Bash(git push:*)"],
    "defaultMode": "auto",
    "deny": [
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(psql:*)",
      "Bash(rm -r:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -f:*)",
      "Bash(ssh:*)",
      "Bash(sudo:*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(id_rsa)"
    ]
  },
  "plansDirectory": "./plans",
  "remoteControlAtStartup": true,
  "skipAutoPermissionPrompt": true,
  "statusLine": {
    "command": "ccstatusline",
    "padding": 0,
    "type": "command"
  },
  "teammateMode": "tmux",
  "theme": "dark-daltonized",
  "tui": "default",
  "voiceEnabled": true
}
