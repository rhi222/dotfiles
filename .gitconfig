[include]
	# userは開発端末ごとに代わりうるのでgitignoreされた別ファイルで管理
	path = ~/.config/git/config-local

# --- Core ---
[core]
	editor = nvim +1 -c 'startinsert'
	whitespace = cr-at-eol
	pager = delta
[init]
	defaultBranch = main
[credential]
	# デフォルトの15分は短すぎる。1時間に延長（SSH鍵運用なら本ヘルパは不要）
	helper = cache --timeout=3600

# --- Operations ---
[push]
	autoSetupRemote = true
[branch]
	# 起点が同名のリモート追跡ブランチのときだけupstreamを設定する。
	# origin/develop 起点で作ったworktreeブランチがdevelopを追跡してしまい、
	# プロンプトの ⇣⇡ がdevelop基準になるのを防ぐ（push時にautoSetupRemoteが自ブランチを設定する）
	autoSetupMerge = simple
[pull]
	rebase = true
[rebase]
	autoStash = true
[fetch]
	prune = true
[merge]
	conflictstyle = zdiff3
[commit]
	template = ~/.config/git/commit-conventions.txt
[status]
	showUntrackedFiles = normal

# --- Diff / Delta ---
[diff]
	colorMoved = default
	algorithm = histogram
[interactive]
	diffFilter = delta --color-only
[delta]
	# https://github.com/dandavison/delta
	# https://zenn.dev/sh090/articles/0796e6b3f4ed94beadc4
	navigate = true    # use n and N to move between diff sections
	light = false      # set to true if you're in a terminal w/ a light background color (e.g. the default macOS terminal)
	#side-by-side = true # lazygitに影響するため

# --- Aliases ---
[alias]
	ap  = add -p
	bd  = branch -D
	co  = commit
	cp  = cherry-pick
	cpush = !git push origin `git rev-parse --abbrev-ref HEAD`
	current-hash="show --format='%H' --no-patch"
	delete-merged-branch = "!f () { git checkout $1; git branch --merged|grep -Ev '\\*|develop|main|master'|xargs git branch -d; };f"
	fe  = fetch
	fsw = "!fish -c git-fsw" # branch 選択 + プレビュー + 自動追跡ブランチ作成
	l  = log
	log = log --graph --all --name-status --pretty=format:"%C(red)%h %C(green)%an %Creset%s %C(yellow)%d%Creset"
	me  = merge
	pl = !git pull origin $(git branch --show-current)
	rs  = restore
	ss = status -s
	sw = switch
	swc = switch -C
	undo = reset --soft HEAD^

# --- External Tools ---
[ghq]
	root = /data/git-repos
[wt]
	relative = true
	nocd = create
	copy = CLAUDE.md
	hook = "bash \"$HOME/scripts/worktree-init.sh\""
